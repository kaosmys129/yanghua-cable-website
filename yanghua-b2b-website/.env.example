# Content Workflow Configuration
PREVIEW_SECRET=your_preview_secret_key_here

# Revalidation Configuration
REVALIDATION_TOKEN=your_revalidation_token_here

# Development Environment
NODE_ENV=development

# Next.js Public Runtime Config
# IMPORTANT:
# - In development, set to your actual dev server origin, e.g. http://localhost:3000 (or http://localhost:3003 if 3000 is in use)
# - In preview deployments, set to the preview URL origin, e.g. https://your-app-preview.vercel.app
# - In production, set to the primary canonical domain, e.g. https://www.yourdomain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_ANALYTICS_ENABLED=false
NEXT_PUBLIC_ERROR_REPORTING_ENABLED=false
NEXT_PUBLIC_MONITORING_ENABLED=false
NEXT_PUBLIC_LOGGING_ENABLED=true

# Tina CMS Local Editing
# 本地后台模式不需要 Tina Cloud 登录。
# `TINA_PUBLIC_IS_LOCAL` 已由 npm scripts 自动注入，通常不需要手动设置。
# 只有在后续接入 Tina Cloud 时才需要下面两个变量。
NEXT_PUBLIC_TINA_CLIENT_ID=
TINA_TOKEN=

# Security / Middleware
ALLOWED_ORIGINS=*

# Optional: WordPress Migration (if needed)
WP_BASE_URL=http://localhost:8080
WP_USERNAME=your_wp_username
WP_PASSWORD=your_wp_password

# Email Service Configuration (zoho enterprise Email)
SMTP_HOST=smtp.zoho.com.cn
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@yhflexiblebusbar.com
SMTP_PASS=Pq2206613!

# Email Recipients
CONTACT_EMAIL=info@yhflexiblebusbar.com
INQUIRY_EMAIL=info@yhflexiblebusbar.com
# Email Sender Configuration
EMAIL_FROM=info@yhflexiblebusbar.com
EMAIL_FROM_NAME=Yanghua Cable

# Multi-language Email Configuration (Optional)
CONTACT_EMAIL_EN=contact@yourdomain.com
CONTACT_EMAIL_ES=contacto@yourdomain.com
INQUIRY_EMAIL_EN=inquiry@yourdomain.com
INQUIRY_EMAIL_ES=consultas@yourdomain.com
EMAIL_FROM_NAME_EN=Yanghua Cable
EMAIL_FROM_NAME_ES=Yanghua Cable
